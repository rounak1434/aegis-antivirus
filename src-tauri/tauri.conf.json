{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aegis Antivirus",
  "version": "0.1.0-phase1",
  "identifier": "dev.aegis.antivirus",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aegis Antivirus",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Windows desktop antivirus UI for AegisService"
  }
}
